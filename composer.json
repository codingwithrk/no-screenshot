{
  "name": "codingwithrk/no-screenshot",
  "description": "A NativePHP Mobile plugin that prevents screenshots, blocks screen recording and global protection in App-switch state in your mobile app.",
  "type": "nativephp-plugin",
  "license": "MIT",
  "authors": [
    {
      "name": "CodingwithRK",
      "email": "pappalarajkumar@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "nativephp/mobile": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Codingwithrk\\NoScreenshot\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Codingwithrk\\NoScreenshot\\NoScreenshotServiceProvider"
      ],
      "aliases": {
        "NoScreenshot": "Codingwithrk\\NoScreenshot\\Facades\\NoScreenshot"
      }
    },
    "nativephp": {
      "manifest": "nativephp.json"
    }
  },
  "require-dev": {
    "pestphp/pest": "^3.0"
  },
  "scripts": {
    "test": "pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}